# Supabase Configuration
# Copy this file to .env and fill in your Supabase project credentials.
# Find these in: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Monime Payment Configuration (Required for Edge Function)
# These should be set in your Supabase project secrets using the Supabase CLI:
# supabase secrets set MONIME_API_KEY=mon_test_... MONIME_SPACE_ID=... SITE_URL=https://...
MONIME_API_KEY=your-monime-api-key
MONIME_SPACE_ID=your-monime-space-id
SITE_URL=http://localhost:3000
